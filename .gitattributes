# Ensure Unix line endings for shell scripts
android-app/gradlew    text eol=lf
*.sh                   text eol=lf
*.kts                  text eol=lf
*.kt                   text eol=lf
*.java                 text eol=lf
*.xml                  text eol=lf
*.json                 text eol=lf
*.yaml                 text eol=lf
*.yml                  text eol=lf
*.md                   text eol=lf
*.properties           text eol=lf
*.toml                 text eol=lf
*.ts                   text eol=lf
*.tsx                  text eol=lf
*.js                   text eol=lf
*.css                  text eol=lf
*.html                 text eol=lf

# Windows batch files keep CRLF
gradlew.bat            text eol=crlf
android-app/gradlew.bat text eol=crlf

# Binaries
*.jks                  binary
*.jar                  binary
*.png                  binary
*.ico                  binary
*.keystore             binary
